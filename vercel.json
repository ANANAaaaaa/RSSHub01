{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "version": 2,
    "builds": [
        {
            "src": "src/server.mjs",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "src/server.mjs"
        }
    ],
    "functions": {
        "src/server.mjs": {
            "includeFiles": "src/templates/**/*.art"
        }
    }
}
